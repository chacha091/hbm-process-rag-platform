pipeline {
    agent any

    environment {
        REGISTRY_HOST = 'registry.example.com'
        REGISTRY_PROJECT = 'manufacturing-platform'
        BACKEND_IMAGE = 'hbm-rag-backend'
        FRONTEND_IMAGE = 'hbm-rag-frontend'
        IMAGE_TAG = "${env.BUILD_NUMBER}"
    }

    options {
        timestamps()
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Code Build') {
            steps {
                sh '''
                    if command -v python3 >/dev/null 2>&1; then
                        python3 --version
                        python3 -m py_compile backend/backend_api.py backend/rag_backend_full.py
                    elif command -v python >/dev/null 2>&1; then
                        python --version
                        python -m py_compile backend/backend_api.py backend/rag_backend_full.py
                    else
                        echo "Python is not installed on this Jenkins agent."
                        exit 1
                    fi
                '''
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                    docker --version
                    docker build -t $REGISTRY_HOST/$REGISTRY_PROJECT/$BACKEND_IMAGE:$IMAGE_TAG -f backend/Dockerfile .
                    docker build -t $REGISTRY_HOST/$REGISTRY_PROJECT/$BACKEND_IMAGE:latest -f backend/Dockerfile .

                    docker build -t $REGISTRY_HOST/$REGISTRY_PROJECT/$FRONTEND_IMAGE:$IMAGE_TAG -f frontend/Dockerfile .
                    docker build -t $REGISTRY_HOST/$REGISTRY_PROJECT/$FRONTEND_IMAGE:latest -f frontend/Dockerfile .
                '''
            }
        }

        stage('Push To Registry') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'container-registry-credentials',
                    usernameVariable: 'REGISTRY_USERNAME',
                    passwordVariable: 'REGISTRY_PASSWORD'
                )]) {
                    sh '''
                        echo "$REGISTRY_PASSWORD" | docker login $REGISTRY_HOST -u "$REGISTRY_USERNAME" --password-stdin

                        docker push $REGISTRY_HOST/$REGISTRY_PROJECT/$BACKEND_IMAGE:$IMAGE_TAG
                        docker push $REGISTRY_HOST/$REGISTRY_PROJECT/$BACKEND_IMAGE:latest

                        docker push $REGISTRY_HOST/$REGISTRY_PROJECT/$FRONTEND_IMAGE:$IMAGE_TAG
                        docker push $REGISTRY_HOST/$REGISTRY_PROJECT/$FRONTEND_IMAGE:latest

                        docker logout $REGISTRY_HOST
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "Pipeline completed successfully."
        }
        failure {
            echo "Pipeline failed. Check the Jenkins console output."
        }
        always {
            sh '''
                if command -v docker >/dev/null 2>&1; then
                    docker images | grep -E "hbm-rag-(backend|frontend)" || true
                else
                    echo "Docker is not installed on this Jenkins agent."
                fi
            '''
        }
    }
}
