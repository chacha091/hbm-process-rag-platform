pipeline {
    agent any

    environment {
        REGISTRY_HOST = 'amdp-registry.skala-ai.com'
        REGISTRY_PROJECT = 'skala26a-ai2'

        BACKEND_IMAGE_NAME = 'sk057-backend'
        FRONTEND_IMAGE_NAME = 'sk057-frontend'

        GIT_CREDENTIALS = 'github-personal-access-token'
        HARBOR_CREDENTIALS = 'harbor-robot-skala26a-ai2'
    }

    options {
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20'))
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Set Image Tag') {
            steps {
                script {
                    env.GIT_COMMIT_SHORT = sh(
                        script: 'git rev-parse --short HEAD',
                        returnStdout: true
                    ).trim()

                    env.IMAGE_TAG = "${BUILD_NUMBER}-${GIT_COMMIT_SHORT}"

                    env.BACKEND_IMAGE = "${REGISTRY_HOST}/${REGISTRY_PROJECT}/${BACKEND_IMAGE_NAME}:${IMAGE_TAG}"
                    env.FRONTEND_IMAGE = "${REGISTRY_HOST}/${REGISTRY_PROJECT}/${FRONTEND_IMAGE_NAME}:${IMAGE_TAG}"

                    env.BACKEND_IMAGE_LATEST = "${REGISTRY_HOST}/${REGISTRY_PROJECT}/${BACKEND_IMAGE_NAME}:latest"
                    env.FRONTEND_IMAGE_LATEST = "${REGISTRY_HOST}/${REGISTRY_PROJECT}/${FRONTEND_IMAGE_NAME}:latest"
                }
            }
        }

        stage('Code Build') {
            steps {
                sh '''
                    python3 --version
                    python3 -m py_compile backend/backend_api.py backend/rag_backend_full.py
                '''
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                    docker build --platform linux/amd64 \
                      -t ${BACKEND_IMAGE} -t ${BACKEND_IMAGE_LATEST} \
                      -f backend/Dockerfile .

                    docker build --platform linux/amd64 \
                      -t ${FRONTEND_IMAGE} -t ${FRONTEND_IMAGE_LATEST} \
                      -f frontend/Dockerfile .
                '''
            }
        }

        stage('Push Image to Harbor') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: "${HARBOR_CREDENTIALS}",
                    usernameVariable: 'HARBOR_USER',
                    passwordVariable: 'HARBOR_PASS'
                )]) {
                    sh '''
                        echo "${HARBOR_PASS}" | docker login ${REGISTRY_HOST} -u "${HARBOR_USER}" --password-stdin

                        docker push ${BACKEND_IMAGE}
                        docker push ${BACKEND_IMAGE_LATEST}
                        docker push ${FRONTEND_IMAGE}
                        docker push ${FRONTEND_IMAGE_LATEST}

                        docker logout ${REGISTRY_HOST}
                    '''
                }
            }
        }

        stage('Update K8s Manifests For Argo CD') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: "${GIT_CREDENTIALS}",
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_TOKEN'
                )]) {
                    sh '''
                        sed -i "s|image: .*sk057-backend:.*|image: ${BACKEND_IMAGE}|g" infra/k8s/deployment-backend.yaml
                        sed -i "s|image: .*sk057-frontend:.*|image: ${FRONTEND_IMAGE}|g" infra/k8s/deployment-frontend.yaml

                        git config user.name "jenkins"
                        git config user.email "jenkins@local"

                        git add infra/k8s/deployment-backend.yaml infra/k8s/deployment-frontend.yaml
                        git commit -m "Update image tags to ${IMAGE_TAG}" || true
                        git push https://${GIT_USER}:${GIT_TOKEN}@github.com/chacha091/hbm-process-rag-platform.git HEAD:main
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "CI and ArgoCD handoff succeeded."
        }
        failure {
            echo "Pipeline failed."
        }
        always {
            sh 'docker image prune -f || true'
        }
    }
}
